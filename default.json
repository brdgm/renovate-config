{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommitsDisabled",
    ":disableRateLimiting"
  ],
  "labels": ["dependencies"],
  "schedule": ["before 4am on the first day of the month"],
  "minimumReleaseAge": "3 days",
  "separateMajorMinor": false,
  "vulnerabilityAlerts": {
    "enabled": false
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/.github/workflows/**"],
      "matchStrings": ["image:\\s*(?<depName>mcr\\.microsoft\\.com/playwright):(?<currentValue>\\S+)"],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "pinDigest", "digest"],
      "groupName": "dependencies",
      "automerge": true
    },
    {
      "matchDepNames": ["@brdgm/brdgm-commons"],
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "pinDigest", "digest"],
      "groupName": "dependencies",
      "automerge": true,
      "minimumReleaseAge": "0 days"
    },
    {
      "matchDepNames": ["vite", "@vitejs/plugin-legacy"],
      "allowedVersions": "<8.0.0"
    },
    {
      "matchDepNames": ["typescript"],
      "allowedVersions": "<6.0.0"
    },
    {
      "matchDepNames": ["mcr.microsoft.com/playwright"],
      "versionCompatibility": "^v?(?<version>[^-]+)(?<compatibility>-.*)?$",
      "versioning": "semver",
      "groupName": "dependencies"
    },
    {
      "matchManagers": ["github-actions"],
      "matchDepNames": ["mcr.microsoft.com/playwright"],
      "enabled": false
    }
  ],
  "ignoreDeps": [
    "sass"
  ]
}
